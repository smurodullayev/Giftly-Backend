# CORS — frontend URL (vergul bilan ajratiladi)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# PostgreSQL
POSTGRES_DB=giftly
POSTGRES_USER=giftly
POSTGRES_PASSWORD=giftly
POSTGRES_HOST=db
POSTGRES_PORT=5432

